# 默认：所有文本文件统一为 LF
* text=auto eol=lf

# Windows 脚本保留 CRLF（避免在 cmd/powershell 下潜在兼容问题）
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 二进制文件（禁止行尾转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
*.tar binary
*.jar binary
*.exe binary
*.dll binary
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.lean text eol=lf